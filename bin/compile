#!/usr/bin/env bash
set -euo pipefail

# Define staging paths
BUILD_DIR="$1"
CACHE_DIR="$2"
DEPS_DIR="$3"

# shellcheck source=./lib/font_utils.sh
source "$(dirname "$0")/lib/font_utils.sh"

# CACHE_DIR is intentionally unused; keep assignment for CF compile script signature.
: "$CACHE_DIR"

echo "-----> Running Crystal Reports Font Injector <-----"

# Look for a Java runtime installed by an earlier buildpack.
JRE_DIR=$(find "$DEPS_DIR" -type d \( -name "jre" -o -name "jdk" \) | head -n 1 || true)

if [ -z "$JRE_DIR" ]; then
    echo "WARNING: JRE directory not found yet. Falling back to app-local Java path..."
    JRE_FONTS_DIR="$BUILD_DIR/.java-buildpack/open_jdk_jre/lib/fonts"
elif [ -d "$JRE_DIR/lib" ]; then
    JRE_FONTS_DIR="$JRE_DIR/lib/fonts"
else
    JRE_FONTS_DIR="$JRE_DIR/fonts"
fi

echo "Target JRE fonts directory: $JRE_FONTS_DIR"

FONT_SOURCE_DIR="$(buildpack_dir_from_script "$0")/fonts"
INSTALLED_COUNT=$(copy_fonts_to_directory "$FONT_SOURCE_DIR" "$JRE_FONTS_DIR")

echo "Successfully injected $INSTALLED_COUNT fonts into JRE."
exit 0
